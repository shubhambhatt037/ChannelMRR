generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Startup {
  slug                String   @id
  name                String
  icon                String?
  description         String?
  website             String?
  country             String?
  category            String?
  targetAudience      String?
  paymentProvider     String?
  foundedDate         DateTime?
  xHandle             String?
  xFollowerCount      Int?
  rank                Int?
  mrr                 Float?
  revenueTotal        Float?
  revenueLast30Days   Float?
  activeSubscriptions Int?
  growth30d           Float?
  growthMRR30d        Float?
  onSale              Boolean  @default(false)
  askingPrice         Float?

  marketingChannels   MarketingChannel[]
  techStack           TechStack[]

  detailFetchedAt     DateTime?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@index([category])
  @@index([targetAudience])
  @@index([country])
  @@index([mrr])
  @@index([xHandle])
  @@map("startup")
}

model MarketingChannel {
  id          Int     @id @default(autoincrement())
  startupSlug String
  slug        String
  category    String?

  startup     Startup @relation(fields: [startupSlug], references: [slug], onDelete: Cascade)

  @@unique([startupSlug, slug])
  @@index([slug])
  @@map("marketing_channel")
}

model TechStack {
  id          Int     @id @default(autoincrement())
  startupSlug String
  slug        String
  category    String?

  startup     Startup @relation(fields: [startupSlug], references: [slug], onDelete: Cascade)

  @@unique([startupSlug, slug])
  @@index([slug])
  @@map("tech_stack")
}

model SyncState {
  id                String   @id @default("singleton")
  lastListSyncAt    DateTime?
  lastDetailSyncAt  DateTime?
  detailCursor      String?
  totalStartups     Int      @default(0)
  detailsFetched    Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@map("sync_state")
}
